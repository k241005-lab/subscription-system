# ── Server ────────────────────────────────────
PORT=5000

# ── MySQL Database ────────────────────────────
DB_HOST=your_database_host
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=subscription_tracker

# ── JWT ───────────────────────────────────────
JWT_SECRET=generate_a_strong_random_secret_key
JWT_EXPIRES_IN=7d

# ── Frontend URL (CORS) ───────────────────────
# For local development: http://localhost:3000 or *
# For production: https://yourusername.github.io/subscriptions-system
CLIENT_URL=https://yourusername.github.io/subscriptions-system
